{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "hide-on-action": true,
  "script-fail-notify": false,
  "scripts": {
    "focus-on-click": {
      "app-name": ".*",
      "exec": "~/.local/bin/swaync-focus",
      "run-on": "action"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "notifications": {
      "vexpand": true
    }
  }
}
